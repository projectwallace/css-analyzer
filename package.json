{
	"name": "@projectwallace/css-analyzer",
	"description": "The best CSS analyzer out there. Check design tokens, complexity, specificity, performance and more.",
	"version": "9.4.0",
	"author": "Bart Veneman",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/projectwallace/css-analyzer.git"
	},
	"homepage": "https://github.com/projectwallace/css-analyzer",
	"issues": "https://github.com/projectwallace/css-analyzer/issues",
	"license": "MIT",
	"type": "module",
	"files": [
		"dist"
	],
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		"types": "./dist/index.d.ts",
		"default": "./dist/index.js"
	},
	"engines": {
		"node": ">=18.0.0"
	},
	"scripts": {
		"lint": "oxlint --config .oxlintrc.json",
		"lint-package": "publint",
		"test": "vitest --coverage",
		"check": "tsc --noEmit",
		"build": "tsdown",
		"knip": "knip"
	},
	"keywords": [
		"projectwallace",
		"wallace",
		"css",
		"stylesheet",
		"stats",
		"statistics",
		"analytics",
		"performance",
		"styleguide",
		"metrics",
		"designsystem",
		"fonts",
		"colors",
		"quality",
		"code"
	],
	"dependencies": {
		"@projectwallace/css-parser": "^0.13.8"
	},
	"devDependencies": {
		"@codecov/rollup-plugin": "^1.9.1",
		"@vitest/coverage-v8": "^4.0.18",
		"knip": "^6.0.4",
		"oxlint": "^1.43.0",
		"prettier": "^3.6.2",
		"publint": "^0.3.17",
		"tsdown": "^0.21.0",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18"
	}
}
